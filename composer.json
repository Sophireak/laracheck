{
  "name": "sophireak/laracheck",
  "description": "A smart pre-push helper script for Laravel teams. Checks setup, fixes safe issues, and explains problems with AI.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "pre-push",
    "git-hook",
    "developer-tools",
    "ai"
  ],
  "authors": [
    {
      "name": "Sophireak",
      "email": "sophireak@example.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/console": "^9.0|^10.0|^11.0|^12.0",
    "illuminate/support": "^9.0|^10.0|11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Sophireak\\Laracheck\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Sophireak\\Laracheck\\LaracheckServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
